# Required in order to use the PIA VPN container.
PIA_USERNAME="op://Dev/3odzyg2lnk7qcm4c2ue5x33fja/username"
PIA_PASSWORD="op://Dev/3odzyg2lnk7qcm4c2ue5x33fja/password"

# Set LOCAL_NETWORK to allow connections to the VPN container from your
# host during local development. The value must be the CIDR of the
# network your host traffic originates from inside Docker:
#   macOS (Docker Desktop): usually 192.168.65.0/24  (VM gateway)
#   Linux (native Docker):  the Compose bridge subnet, e.g. 172.19.0.0/16
# To find it, check your Docker subnet settings in Docker Desktop at
# "Settings > Resources > Network" or run this command:
#   docker run --rm alpine sh -c "getent hosts host.docker.internal | awk '{print \$1}'"
# then connect to localhost:3001 and note the source IP.
# LOCAL_NETWORK=192.168.65.0/24


